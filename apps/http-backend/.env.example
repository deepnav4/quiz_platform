# ──────────────────────────────────────────
# HTTP Backend Environment Variables
# Copy this file to .env in apps/http-backend/
# ──────────────────────────────────────────

# Server port (default: 3000)
PORT=3000

# JWT secret for auth tokens (CHANGE IN PRODUCTION!)
JWT_SECRET=quizora-dev-secret-key-2024

# Token expiry duration
JWT_EXPIRES_IN=7d

# (Optional) AI API key for AI-generated quizzes
AI_API_KEY=

# (Optional) OCR API key for image-based questions
OCR_API_KEY=

# Database URL — set by Prisma / @repo/db
# DATABASE_URL is usually in packages/db/.env
